---
import { getTranslations, type Locale } from "../i18n";

interface Props {
  locale?: Locale;
}

const { pathname } = Astro.url;
const isHomePage = pathname === "/";
const locale = Astro.props.locale || Astro.locals.locale || "fr";
const t = getTranslations(locale);
const otherLocale = locale === "fr" ? "en" : "fr";
---

<header id="header">
  <div class="header__wrapper">
    <div class="header__cols">
      <div class="header__col header__col--left">
        <a class="header__site-title" href="/" aria-current="true"
          >Clément Maillet</a
        >
        <div
          class="header__lang-switcher"
          role="group"
          aria-label={t.header.languageSelector || "Sélecteur de langue"}
        >
          <button
            class={`header__lang-btn ${locale === "fr" ? "header__lang-btn--active" : ""}`}
            data-locale="fr"
            aria-pressed={locale === "fr" ? "true" : "false"}
            aria-label="Français"
            title="Français"
          >
            <span class="header__lang-icon" aria-hidden="true">🇫🇷</span>
            <span class="header__lang-text">FR</span>
          </button>
          <button
            class={`header__lang-btn ${locale === "en" ? "header__lang-btn--active" : ""}`}
            data-locale="en"
            aria-pressed={locale === "en" ? "true" : "false"}
            aria-label="English"
            title="English"
          >
            <span class="header__lang-icon" aria-hidden="true">🇬🇧</span>
            <span class="header__lang-text">EN</span>
          </button>
        </div>
      </div>

      <div class="header__col header__col--right">
        <button
          class="header__burger"
          aria-label={t.header.menuLabel}
          aria-expanded="false"
        >
          <span class="header__burger-line"></span>
          <span class="header__burger-line"></span>
          <span class="header__burger-line"></span>
        </button>

        <nav class="header__navigation header__navigation--desktop">
          <ul class="header__menu">
            {
              isHomePage && (
                <>
                  <li class="header__menu-item">
                    <a
                      href="#about"
                      class="header__menu-link header__menu-link--about"
                    >
                      {t.header.about}
                    </a>
                  </li>
                  <li class="header__menu-item">
                    <a
                      href="#exph"
                      class="header__menu-link header__menu-link--skills"
                    >
                      {t.header.skills}
                    </a>
                  </li>
                  <li class="header__menu-item">
                    <a
                      href="#project"
                      class="header__menu-link header__menu-link--projects"
                    >
                      {t.header.projects}
                    </a>
                  </li>
                  <li class="header__menu-item header__menu-item--cta">
                    <a
                      draggable="false"
                      href="#contact"
                      class="header__menu-link header__menu-link--contact"
                    >
                      {t.header.contact}
                    </a>
                  </li>
                </>
              )
            }
            {
              !isHomePage && (
                <li class="header__menu-item header__menu-item--cta">
                  <a
                    draggable="false"
                    href="/"
                    class="header__menu-link header__menu-link--contact"
                  >
                    {t.header.backToPortfolio}
                  </a>
                </li>
              )
            }
          </ul>
        </nav>
      </div>
    </div>
  </div>
</header>

<!-- Mobile navigation overlay - outside header for proper z-index -->
<div class="mobile-nav-overlay" id="mobile-nav-overlay">
  <button
    class="mobile-nav-close"
    id="mobile-nav-close"
    aria-label={t.header.closeMenuLabel}
  >
    <span class="mobile-nav-close__line"></span>
    <span class="mobile-nav-close__line"></span>
  </button>
  <nav class="mobile-nav">
    <ul class="mobile-nav__menu">
      {
        isHomePage && (
          <>
            <li class="mobile-nav__item">
              <a href="#about" class="mobile-nav__link">
                {t.header.about}
              </a>
            </li>
            <li class="mobile-nav__item">
              <a href="#exph" class="mobile-nav__link">
                {t.header.skills}
              </a>
            </li>
            <li class="mobile-nav__item">
              <a href="#project" class="mobile-nav__link">
                {t.header.projects}
              </a>
            </li>
            <li class="mobile-nav__item mobile-nav__item--cta">
              <a href="#contact" class="mobile-nav__link">
                {t.header.contact}
              </a>
            </li>
          </>
        )
      }
      {
        !isHomePage && (
          <li class="mobile-nav__item mobile-nav__item--cta">
            <a href="/" class="mobile-nav__link">
              {t.header.backToPortfolio}
            </a>
          </li>
        )
      }
      <li class="mobile-nav__item mobile-nav__item--lang">
        <button
          class="mobile-nav__lang-switcher"
          data-locale={otherLocale}
          aria-label={locale === "fr"
            ? "Switch to English"
            : "Passer en français"}
        >
          {otherLocale === "en" ? "English" : "Français"}
        </button>
      </li>
    </ul>
  </nav>
</div>

<script>
  // Compact header on scroll out of hero section
  const setupHeaderScroll = () => {
    const header = document.getElementById("header");
    const heroSection = document.getElementById("hero");

    if (!header || !heroSection) return;

    // Use Intersection Observer for better performance
    const observerOptions = {
      root: null,
      threshold: 0.1,
      rootMargin: "-80px 0px 0px 0px", // Trigger slightly before leaving hero
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        // When hero section is NOT visible, add compact class
        if (!entry.isIntersecting) {
          header.classList.add("header--compact");
        } else {
          header.classList.remove("header--compact");
        }
      });
    }, observerOptions);

    observer.observe(heroSection);
  };

  // Language switcher with improved UX feedback
  const setupLangSwitcher = () => {
    const langButtons = document.querySelectorAll(
      ".header__lang-btn, .mobile-nav__lang-switcher",
    );

    langButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const newLocale = (btn as HTMLElement).dataset.locale;
        const isActive = btn.classList.contains("header__lang-btn--active");

        // Don't switch if already active
        if (isActive) return;

        if (newLocale) {
          // Add loading state feedback
          btn.classList.add("header__lang-btn--loading");

          // Set cookie for 1 year
          document.cookie = `locale=${newLocale};path=/;max-age=31536000;SameSite=Lax`;

          // Reload the page with smooth transition
          setTimeout(() => {
            window.location.reload();
          }, 150);
        }
      });
    });
  };

  // Initialize on load
  setupHeaderScroll();
  setupLangSwitcher();

  // Re-initialize on view transitions (if using Astro view transitions)
  document.addEventListener("astro:page-load", () => {
    setupHeaderScroll();
    setupLangSwitcher();
  });
</script>

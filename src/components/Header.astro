---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import type { Language } from "../i18n/config";

interface Props {
  lang: Language;
  translations: any;
}

const { lang, translations } = Astro.props;
const { pathname } = Astro.url;
const isHomePage = pathname === "/";
---

<header id="header">
  <div class="header__wrapper">
    <div class="header__cols">
      <div class="header__col header__col--left">
        <a class="header__site-title" href="/" aria-current="true"
          >Clément Maillet</a
        >
      </div>

      <div class="header__col header__col--right">
        <button
          class="header__burger"
          id="burger-toggle"
          aria-label="Menu"
          aria-expanded="false"
        >
          <span class="header__burger-line"></span>
          <span class="header__burger-line"></span>
          <span class="header__burger-line"></span>
        </button>

        <nav class="header__navigation">
          <ul class="header__menu">
            {
              isHomePage && (
                <>
                  <li class="header__menu-item">
                    <a
                      href="#about"
                      class="header__menu-link header__menu-link--about"
                    >
                      {translations.header.nav.about}
                    </a>
                  </li>
                  <li class="header__menu-item">
                    <a
                      href="#exph"
                      class="header__menu-link header__menu-link--skills"
                    >
                      {translations.header.nav.skills}
                    </a>
                  </li>
                  <li class="header__menu-item">
                    <a
                      href="#project"
                      class="header__menu-link header__menu-link--projects"
                    >
                      {translations.header.nav.projects}
                    </a>
                  </li>
                  <li class="header__menu-item header__menu-item--cta">
                    <a
                      draggable="false"
                      href="#contact"
                      class="header__menu-link header__menu-link--contact"
                    >
                      {translations.header.nav.contact}
                    </a>
                  </li>
                </>
              )
            }
            {
              !isHomePage && (
                <li class="header__menu-item header__menu-item--cta">
                  <a
                    draggable="false"
                    href="/"
                    class="header__menu-link header__menu-link--contact"
                  >
                    {translations.header.nav.backToPortfolio}
                  </a>
                </li>
              )
            }
          </ul>
        </nav>

        <div class="header__lang-desktop">
          <LanguageSwitcher currentLang={lang} />
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Menu mobile plein écran -->
<div class="mobile-menu" id="mobile-menu">
  <div class="mobile-menu__header">
    <LanguageSwitcher currentLang={lang} />
    <button
      class="mobile-menu__close"
      id="mobile-menu-close"
      aria-label="Fermer le menu"
    >
      <span class="mobile-menu__close-line"></span>
      <span class="mobile-menu__close-line"></span>
    </button>
  </div>
  <nav class="mobile-menu__nav">
    {
      isHomePage && (
        <>
          <a href="#about" class="mobile-menu__link">
            {translations.header.nav.about}
          </a>
          <a href="#exph" class="mobile-menu__link">
            {translations.header.nav.skills}
          </a>
          <a href="#project" class="mobile-menu__link">
            {translations.header.nav.projects}
          </a>
          <a href="#contact" class="mobile-menu__link mobile-menu__link--cta">
            {translations.header.nav.contact}
          </a>
        </>
      )
    }
    {
      !isHomePage && (
        <a href="/" class="mobile-menu__link mobile-menu__link--cta">
          {translations.header.nav.backToPortfolio}
        </a>
      )
    }
  </nav>
</div>

<script>
  let controller: AbortController | null = null;

  const init = () => {
    if (controller) controller.abort();
    controller = new AbortController();
    const { signal } = controller;

    const burgerBtn = document.getElementById("burger-toggle");
    const closeBtn = document.getElementById("mobile-menu-close");
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileLinks = document.querySelectorAll(".mobile-menu__link");
    const header = document.getElementById("header");
    const heroSection = document.getElementById("hero");

    if (!burgerBtn || !mobileMenu || !closeBtn) return;

    // Animation de réduction du header au scroll
    if (header && heroSection) {
      const observerOptions = {
        root: null,
        threshold: 0,
        rootMargin: "-100px 0px 0px 0px",
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) {
            header.classList.add("header--compact");
          } else {
            header.classList.remove("header--compact");
          }
        });
      }, observerOptions);

      observer.observe(heroSection);
    }

    let savedScrollY = 0;

    const openMenu = () => {
      // Positionner la croix exactement sur le burger
      const rect = burgerBtn.getBoundingClientRect();
      closeBtn.style.position = "fixed";
      closeBtn.style.top = `${rect.top + 10}px`;
      closeBtn.style.left = `${rect.left + 10}px`;

      // Sauvegarder la position de scroll et bloquer le body
      savedScrollY = window.scrollY;
      document.body.style.position = "fixed";
      document.body.style.top = `-${savedScrollY}px`;
      document.body.style.left = "0";
      document.body.style.right = "0";

      mobileMenu.classList.add("mobile-menu--active");
    };

    const closeMenu = () => {
      mobileMenu.classList.remove("mobile-menu--active");

      // Restaurer la position de scroll
      document.body.style.position = "";
      document.body.style.top = "";
      document.body.style.left = "";
      document.body.style.right = "";
      window.scrollTo(0, savedScrollY);
    };

    const scrollToSection = (sectionId: string) => {
      const section = document.getElementById(sectionId);
      if (section) {
        const header = document.getElementById("header");
        const headerHeight = header ? header.offsetHeight : 0;
        const sectionTop = section.getBoundingClientRect().top + window.scrollY;
        window.scrollTo({
          top: sectionTop - headerHeight,
          behavior: "smooth",
        });
      }
    };

    burgerBtn.addEventListener("click", openMenu, { signal });
    closeBtn.addEventListener("click", closeMenu, { signal });

    mobileLinks.forEach((link) => {
      link.addEventListener(
        "click",
        (e) => {
          const href = link.getAttribute("href");
          if (href && href.startsWith("#")) {
            e.preventDefault();
            closeMenu();
            setTimeout(() => {
              scrollToSection(href.substring(1));
            }, 100);
          } else {
            closeMenu();
          }
        },
        { signal },
      );
    });

    // Tous les liens d'ancrage (header desktop + hero CTA)
    const anchorLinks = document.querySelectorAll(
      '.header__menu-link[href^="#"], .hero__cta-button[href^="#"]',
    );
    anchorLinks.forEach((link) => {
      link.addEventListener(
        "click",
        (e) => {
          e.preventDefault();
          const href = link.getAttribute("href");
          if (href) {
            scrollToSection(href.substring(1));
          }
        },
        { signal },
      );
    });

    document.addEventListener(
      "keydown",
      (e) => {
        if (
          e.key === "Escape" &&
          mobileMenu.classList.contains("mobile-menu--active")
        ) {
          closeMenu();
        }
      },
      { signal },
    );
  };

  init();
  document.addEventListener("astro:page-load", init);
</script>

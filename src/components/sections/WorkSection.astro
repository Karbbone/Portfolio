---
import inovera from "../../assets/inovera.png";
import mediamag from "../../assets/mediamag.png";

import adonisLogo from "../../assets/technos/adonis.svg";
import cplusplusLogo from "../../assets/technos/cplusplus.svg";
import mysqlLogo from "../../assets/technos/mysql.svg";
import phpLogo from "../../assets/technos/php.svg";
import pythonLogo from "../../assets/technos/python.svg";
import reactLogo from "../../assets/technos/react.svg";
import symfonyLogo from "../../assets/technos/symfony.svg";
import typescriptLogo from "../../assets/technos/typescript.svg";

const workExperiences = [
  {
    company: {
      name: "Médiamag",
      logo: mediamag,
      website: "https://www.mediamag-systeme.com/",
    },
    position: "Développeur Full Stack",
    dateRange: "Avril 2023 - Août 2024",
    tasks: [
      "Développement de plusieurs applications internes afin d'améliorer l'autonomie des employés.",
      "Développement d'une application permettant de s'ouvrir à de nouveaux clients sur le marché avec une nouvelle offre, permettant aux utilisateurs de s'enregistrer sans avoir à passer par les voix professionnelles de Médiamag.",
      "Création de modules externes pour l'application principale de la société en C++, Python.",
    ],
    technologies: [
      { name: "AdonisJS", logo: adonisLogo, url: "https://adonisjs.com/" },
      { name: "C++", logo: cplusplusLogo, url: "https://cplusplus.com/" },
      { name: "MySQL", logo: mysqlLogo, url: "https://www.mysql.com/" },
      { name: "Python", logo: pythonLogo, url: "https://www.python.org/" },
      { name: "React", logo: reactLogo, url: "https://react.dev/" },
      {
        name: "TypeScript",
        logo: typescriptLogo,
        url: "https://www.typescriptlang.org/",
      },
    ],
  },
  {
    company: {
      name: "Inovera",
      logo: inovera,
      website: "https://www.inovera.fr/",
    },
    position: "Développeur Full Stack",
    dateRange: "Novembre 2024",
    isCurrentJob: true,
    tasks: [
      "Migration d'une application Symfony vers une nouvelle solution front-end en React avec transformation du backend Symfony en API REST/JSON.",
      "Application du nouveau design sur les applications de la société.",
      "Gestion et coordination des projets via Jira avec planification des tickets et méthodologie Kanban.",
      "Maintenance et développement de nouvelles fonctionnalités sur les applications existantes de la société.",
    ],
    technologies: [
      { name: "MySQL", logo: mysqlLogo, url: "https://www.mysql.com/" },
      { name: "PHP", logo: phpLogo, url: "https://www.php.net/" },
      { name: "React", logo: reactLogo, url: "https://react.dev/" },
      { name: "Symfony", logo: symfonyLogo, url: "https://symfony.com/" },
      {
        name: "TypeScript",
        logo: typescriptLogo,
        url: "https://www.typescriptlang.org/",
      },
    ],
  },
];
---

<section id="work">
  <div class="work__wrapper">
    <h2 class="work__title" data-reveal="up">
      <span>C'est un réel plaisir <br /> de travailler ensemble</span>
    </h2>
    
    <div class="work__content" data-reveal="up" data-reveal-delay="1">
      <!-- Timeline sidebar -->
      <nav class="work__timeline" aria-label="Sélection d'entreprise">
        <div class="work__timeline__line"></div>
        {
          workExperiences.map((experience, index) => (
            <button
              class={`work__timeline__item ${
                index === 0 ? "work__timeline__item--active" : ""
              }`}
              data-index={index}
              type="button"
              aria-label={`Afficher l'expérience chez ${experience.company.name}`}
            >
              <div class="work__timeline__marker">
                <span class="work__timeline__dot"></span>
              </div>
              <div class="work__timeline__card">
                <div class="work__timeline__logo">
                  <img
                    src={experience.company.logo.src}
                    alt={experience.company.name}
                  />
                </div>
                <div class="work__timeline__info">
                  <span class="work__timeline__company">
                    {experience.company.name}
                  </span>
                  <span class="work__timeline__period">
                    {experience.dateRange}
                    {experience.isCurrentJob && (
                      <span class="work__timeline__current-dot" title="Poste actuel"></span>
                    )}
                  </span>
                </div>
              </div>
            </button>
          ))
        }
      </nav>

      <!-- Experience cards -->
      <div class="work__experiences">
        {
          workExperiences.map((experience, index) => (
            <article
              class="work__card"
              style={index !== 0 ? "display: none;" : ""}
              data-work-item={index}
            >
              <header class="work__card__header">
                <div class="work__card__top">
                  <div class="work__card__company-info">
                    <img
                      src={experience.company.logo.src}
                      alt={experience.company.name}
                      class="work__card__logo"
                    />
                    <div class="work__card__company-text">
                      <span class="work__card__company">{experience.company.name}</span>
                      <span class="work__card__period">
                        {experience.dateRange}
                        {experience.isCurrentJob && " - Présent"}
                      </span>
                    </div>
                  </div>
                  <a
                    href={experience.company.website}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn btn--green work__card__link"
                    draggable="false"
                  >
                    <span>Voir le site</span>
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                      <polyline points="15 3 21 3 21 9" />
                      <line x1="10" y1="14" x2="21" y2="3" />
                    </svg>
                  </a>
                </div>
                <div class="work__card__position-wrapper">
                  <h3 class="work__card__position">{experience.position}</h3>
                  {experience.isCurrentJob && (
                    <span class="work__card__status">
                      <span class="work__card__status-dot"></span>
                      Poste actuel
                    </span>
                  )}
                </div>
              </header>

              <div class="work__card__body">
                <div class="work__card__section">
                  <div class="work__card__section-header">
                    <svg class="work__card__section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                    </svg>
                    <h4 class="work__card__subtitle">Missions & Réalisations</h4>
                  </div>
                  <ul class="work__card__tasks">
                    {experience.tasks.map((task, taskIndex) => (
                      <li class="work__card__task" style={`--task-index: ${taskIndex}`}>
                        <span class="work__card__task-number">{String(taskIndex + 1).padStart(2, '0')}</span>
                        <span class="work__card__task-text">{task}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <footer class="work__card__footer">
                <div class="work__card__section-header">
                  <svg class="work__card__section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                  </svg>
                  <h4 class="work__card__subtitle">Stack Technique</h4>
                </div>
                <div class="work__card__technologies">
                  {experience.technologies.map((tech) => (
                    <a
                      href={tech.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="work__card__tech"
                      title={tech.name}
                    >
                      <img src={tech.logo.src} alt={tech.name} />
                      <span>{tech.name}</span>
                    </a>
                  ))}
                </div>
              </footer>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style is:global>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .work__card.is-animating-in {
    animation: fadeInUp 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>

<script>
  const timelineItems = document.querySelectorAll(".work__timeline__item");
  const workCards = document.querySelectorAll("[data-work-item]");

  function switchExperience(selectedIndex: number) {
    // Update timeline active state
    timelineItems.forEach((item) => {
      item.classList.remove("work__timeline__item--active");
    });
    timelineItems[selectedIndex]?.classList.add("work__timeline__item--active");

    // Switch work card with animation
    workCards.forEach((card) => {
      const cardElement = card as HTMLElement;
      const cardIndex = parseInt(cardElement.dataset.workItem || "0", 10);

      cardElement.classList.remove("is-animating-in");

      if (cardIndex === selectedIndex) {
        cardElement.style.display = "";
        // Trigger animation after a small delay
        setTimeout(() => {
          cardElement.classList.add("is-animating-in");
        }, 10);
      } else {
        cardElement.style.display = "none";
      }
    });
  }

  timelineItems.forEach((item, index) => {
    item.addEventListener("click", () => {
      switchExperience(index);
    });
  });
</script>

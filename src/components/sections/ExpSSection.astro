---
// Import des icônes pour les soft skills
import chatIcon from "../../assets/chat.svg";
import collabIcon from "../../assets/collab.svg";
import fdnIcon from "../../assets/fdn.png";
import loopIcon from "../../assets/loop.svg";
import { getTranslations, type Locale } from "../../i18n";

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale || Astro.locals.locale || "fr";
const t = getTranslations(locale);

// Helper to render HTML with highlight tags
function renderWithHighlight(text: string): string {
  return text
    .replace(/<highlight>/g, '<span class="highlighted highlighted-blue">')
    .replace(/<\/highlight>/g, "</span>");
}
---

<section id="exps">
  <div class="exps__wrapper">
    <h2 class="exps__title" data-reveal="up">
      <span set:html={t.expS.title} />
    </h2>
    <div class="exps__grid">
      <div class="exps__card" data-reveal="up" data-reveal-delay="1">
        <div class="exps__card-header">
          <h3 class="exps__card-title">{t.expS.listening.title}</h3>
          <div class="exps__card-icon">
            <img src={chatIcon.src} alt="" />
          </div>
        </div>
        <p
          class="exps__card-text"
          set:html={renderWithHighlight(t.expS.listening.description)}
        />
      </div>

      <div class="exps__card" data-reveal="up" data-reveal-delay="2">
        <div class="exps__card-header">
          <h3 class="exps__card-title">{t.expS.teamwork.title}</h3>
          <div class="exps__card-icon">
            <img src={collabIcon.src} alt="" />
          </div>
        </div>
        <p
          class="exps__card-text"
          set:html={renderWithHighlight(t.expS.teamwork.description)}
        />
      </div>

      <div class="exps__card" data-reveal="up" data-reveal-delay="3">
        <div class="exps__card-header">
          <h3 class="exps__card-title">{t.expS.curious.title}</h3>
          <div class="exps__card-icon">
            <img src={loopIcon.src} alt="" />
          </div>
        </div>
        <p
          class="exps__card-text"
          set:html={renderWithHighlight(t.expS.curious.description1)}
        />
        <p class="exps__card-text">
          {t.expS.curious.description2}
        </p>
      </div>

      <div class="exps__card" data-reveal="up" data-reveal-delay="4">
        <div class="exps__card-header">
          <h3 class="exps__card-title">{t.expS.volunteer.title}</h3>
          <div class="exps__card-icon">
            <img src={fdnIcon.src} alt="" />
          </div>
        </div>
        <p
          class="exps__card-text"
          set:html={renderWithHighlight(t.expS.volunteer.description)}
        />
        <a
          href="https://www.fresquedunumerique.org/"
          target="_blank"
          rel="noopener noreferrer"
          class="exps__card-cta"
          draggable="false">{t.expS.volunteer.cta}</a
        >
      </div>
    </div>
  </div>
</section>

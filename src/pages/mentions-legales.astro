---
import "normalize.css/normalize.css";
import Layout from "../layouts/Layout.astro";
import "../sass/main.scss";
import { getTranslations } from "../i18n";

const locale = Astro.locals.locale;
const t = getTranslations(locale);
---

<Layout locale={locale}>
  <div class="legal-page" id="legal-page">
    <section class="legal-page__wrapper">
      <h1 class="legal-page__title">{t.legal.title}</h1>

      <section class="legal-page__section">
        <h2>{t.legal.editorTitle}</h2>
        <p>
          <strong>{t.legal.editorName}</strong> Clément Maillet<br />
          <strong>{t.legal.editorStatus}</strong>
          {t.legal.editorStatusValue}<br />
          <strong>{t.legal.editorLocation}</strong>
          {t.legal.editorLocationValue}<br />
          <strong>{t.legal.editorEmail}</strong> clement.maillet56@gmail.com<br
          />
        </p>
      </section>

      <section class="legal-page__section">
        <h2>{t.legal.publicationDirectorTitle}</h2>
        <p>
          <strong>{t.legal.publicationDirector}</strong> Clément Maillet<br />
          <strong>{t.legal.publicationContact}</strong> clement.maillet56@gmail.com
        </p>
      </section>

      <section class="legal-page__section">
        <h2>{t.legal.hostingTitle}</h2>
        <p>
          <strong>{t.legal.hostingProvider}</strong> Hetzner Online GmbH<br />
          <strong>{t.legal.hostingAddress}</strong> Industriestr. 25, 91710 Gunzenhausen,
          Allemagne<br />
          <strong>{t.legal.hostingPhone}</strong> +49 (0)9831 505-0<br />
          <strong>{t.legal.hostingWebsite}</strong>
          <a
            href="https://www.hetzner.com"
            target="_blank"
            rel="noopener noreferrer">www.hetzner.com</a
          ><br />
          <em>{t.legal.hostingNote}</em>
        </p>
      </section>

      <section class="legal-page__section">
        <h2>{t.legal.intellectualPropertyTitle}</h2>
        <p>{t.legal.intellectualProperty1}</p>
        <p>{t.legal.intellectualProperty2}</p>
      </section>

      <section class="legal-page__section">
        <h2>{t.legal.personalDataTitle}</h2>
        <p>{t.legal.personalData1}</p>
        <p>{t.legal.personalData2}</p>
      </section>

      <section class="legal-page__section">
        <h2>{t.legal.cookiesTitle}</h2>
        <p>{t.legal.cookiesIntro}</p>
        <ul>
          <li>
            <strong>Umami Analytics :</strong>
            {t.legal.cookiesUmami}
          </li>
          <li>
            <strong>Google reCAPTCHA :</strong>
            {t.legal.cookiesRecaptcha}
          </li>
          <li>
            <strong>EmailJS :</strong>
            {t.legal.cookiesEmailjs}
          </li>
        </ul>
        <p>{t.legal.cookiesNote1}</p>
        <p>{t.legal.cookiesNote2}</p>
      </section>

      <section class="legal-page__section">
        <h2>{t.legal.liabilityTitle}</h2>
        <p>{t.legal.liability1}</p>
        <p>{t.legal.liability2}</p>
      </section>

      <section class="legal-page__section">
        <h2>{t.legal.accessibilityTitle}</h2>
        <p>{t.legal.accessibility}</p>
      </section>

      <section class="legal-page__section">
        <h2>{t.legal.lawTitle}</h2>
        <p>{t.legal.law}</p>
      </section>
    </section>
  </div>
</Layout>
